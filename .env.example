# ─── Database ───
# Supabase (EU region — Frankfurt)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ───
# Supabase Auth handles this, but you may need:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Payments ───
# Stripe — OPTIONAL. Leave all unset for the open-source / self-host build:
# the app runs fully on the free plan, billing UI is hidden, and webhook/
# checkout routes are inert. Set all four on the hosted/commercial build to
# enable live subscriptions (Pro plan, €39/mo, unlimited employees).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...   # Create the Pro product in your Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email ───
# Resend (transactional emails)
RESEND_API_KEY=re_...

# ─── Environment ───
NODE_ENV=development
