# ─── Database ───
# Supabase (EU region — Frankfurt)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ───
# Supabase Auth handles this, but you may need:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "true" once Google OAuth is configured on your (hosted) Supabase project.
# Requires a public HTTPS URL — does NOT work against local supabase start.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=

# ─── Payments ───
# Stripe — OPTIONAL. Leave all unset for the open-source / self-host build:
# the app runs fully on the free plan, billing UI is hidden, and webhook/
# checkout routes are inert. Set all four on the hosted/commercial build to
# enable live subscriptions (Pro plan, €39/mo, unlimited employees).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Tiered flatrate — one recurring monthly price per tier (create in your Stripe dashboard):
STRIPE_TEAM_PRICE_ID=price_...      # €9/mo, ≤10 employees
STRIPE_BUSINESS_PRICE_ID=price_...   # €59/mo, ≤50 employees
STRIPE_PRO_PRICE_ID=price_...        # €99/mo, unlimited
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email ───
# Resend (transactional emails)
RESEND_API_KEY=re_...

# ─── Environment ───
NODE_ENV=development
